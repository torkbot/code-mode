{
  "name": "@torkbot/code-mode",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Runtime-agnostic code-mode program launcher contracts and adapters.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/torkbot/code-mode"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runner": {
      "types": "./dist/runner/index.d.ts",
      "default": "./dist/runner/index.js"
    },
    "./runner/source": {
      "types": "./dist/runner/source.d.ts",
      "default": "./dist/runner/source.js"
    },
    "./host-node": {
      "types": "./dist/host-node/index.d.ts",
      "default": "./dist/host-node/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "benchmark:host-node-memory": "node --run build && node scripts/benchmark-host-node-memory.mjs",
    "build": "rm -rf dist && tsc --project tsconfig.build.json --pretty && node scripts/write-runner-source.mjs",
    "test": "node --test",
    "types:generate": "rm -rf dist && tsc --project tsconfig.build.json --pretty --emitDeclarationOnly",
    "typecheck": "tsc --noEmit --pretty",
    "prepublishOnly": "node --run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@types/node": "^24.12.0",
    "amaro": "^1.1.10",
    "typebox": "^1.3.3",
    "typescript": "^7.0.2"
  }
}
